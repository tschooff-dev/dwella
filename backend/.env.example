# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Neon recommended for production)
DATABASE_URL="postgresql://postgres:password@localhost:5432/dwella"

# Clerk Auth
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# Stripe (payments + identity verification)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Plaid (income verification)
# Get keys at dashboard.plaid.com
PLAID_CLIENT_ID=replace_me
PLAID_SECRET=replace_me
# sandbox | development | production
PLAID_ENV=sandbox

# Cloudflare R2 (document storage)
# Get keys at dash.cloudflare.com -> R2 -> Manage API Tokens
# R2 is S3-compatible — same SDK, no egress fees
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=dwella-documents
# Your R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://replace_me.r2.cloudflarestorage.com
