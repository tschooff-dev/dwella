generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LANDLORD
  TENANT
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

enum PaymentStatus {
  PAID
  DUE
  LATE
  PARTIAL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VerificationProvider {
  PLAID
  STRIPE_IDENTITY
}

enum VerificationStatus {
  PENDING
  PROCESSING
  VERIFIED
  FAILED
  REQUIRES_INPUT
}

model User {
  id            String    @id @default(cuid())
  clerkId       String?   @unique
  email         String    @unique
  firstName     String
  lastName      String
  role          Role
  phone         String?
  avatarUrl     String?
  stripeId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties          Property[]
  portfolios          Portfolio[]
  leases              Lease[]
  payments            Payment[]
  maintenanceRequests MaintenanceRequest[]
  applications        Application[]
  uploadedDocuments   Document[]
  sentMessages        Message[]            @relation("SentMessages")
  landlordSettings    LandlordSettings?

  @@map("users")
}

model Portfolio {
  id          String     @id @default(cuid())
  name        String
  color       String     @default("indigo")
  landlordId  String
  landlord    User       @relation(fields: [landlordId], references: [id])
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("portfolios")
}

model Property {
  id          String     @id @default(cuid())
  name        String
  address     String
  city        String
  state       String
  zip         String
  imageUrl    String?
  description String?
  landlordId  String
  landlord    User       @relation(fields: [landlordId], references: [id])
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])
  units       Unit[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("properties")
}

model Unit {
  id            String     @id @default(cuid())
  unitNumber    String
  floor         Int?
  bedrooms      Int
  bathrooms     Float
  squareFeet    Int?
  rentAmount    Float
  depositAmount Float?
  status        UnitStatus @default(VACANT)
  applyToken    String?    @unique
  propertyId    String
  property      Property   @relation(fields: [propertyId], references: [id])
  leases        Lease[]
  applications  Application[]
  maintenanceRequests MaintenanceRequest[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([propertyId, unitNumber])
  @@map("units")
}

model Lease {
  id          String      @id @default(cuid())
  unitId      String
  unit        Unit        @relation(fields: [unitId], references: [id])
  tenantId    String
  tenant      User        @relation(fields: [tenantId], references: [id])
  startDate   DateTime
  endDate     DateTime
  rentAmount  Float
  depositPaid Float?
  status      LeaseStatus @default(ACTIVE)
  documentUrl          String?
  landlordDeletedAt    DateTime?
  payments    Payment[]
  messages    Message[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leases")
}

model Payment {
  id              String        @id @default(cuid())
  leaseId         String
  lease           Lease         @relation(fields: [leaseId], references: [id])
  tenantId        String
  tenant          User          @relation(fields: [tenantId], references: [id])
  amount          Float
  dueDate         DateTime
  paidDate        DateTime?
  status          PaymentStatus
  stripePaymentId String?
  method          String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

model Application {
  id              String            @id @default(cuid())
  unitId          String
  unit            Unit              @relation(fields: [unitId], references: [id])
  applicantId     String?
  applicant       User?             @relation(fields: [applicantId], references: [id])
  applicantName   String
  applicantEmail  String
  applicantPhone  String?

  // Self-reported (pre-verification)
  monthlyIncome   Float?
  creditScore     Int?

  // Verified data from Plaid (no PII stored — only derived facts)
  plaidVerified         Boolean   @default(false)
  verifiedMonthlyIncome Float?    // from Plaid Income
  verifiedEmployer      String?   // employer name only
  incomeVerifiedAt      DateTime?

  // Identity verification via Stripe Identity
  identityVerified    Boolean   @default(false)
  identityVerifiedAt  DateTime?

  // References & consent
  previousLandlordName  String?
  previousLandlordPhone String?
  ssnLastFour           String?
  backgroundCheckConsent Boolean  @default(false)
  consentAt             DateTime?

  // AI scoring
  aiScore     Int?
  aiSummary   String?

  status      ApplicationStatus @default(PENDING)
  notes       String?
  submittedAt DateTime          @default(now())
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  verificationSessions VerificationSession[]
  documents            Document[]

  @@map("applications")
}

// Tracks external verification sessions (Plaid, Stripe Identity)
// Stores session IDs and status only — no raw PII
model VerificationSession {
  id            String               @id @default(cuid())
  applicationId String
  application   Application          @relation(fields: [applicationId], references: [id])
  provider      VerificationProvider
  externalId    String               // Plaid item_id or Stripe verification session id
  status        VerificationStatus   @default(PENDING)
  resultSummary Json?                // sanitized non-PII result fields only
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("verification_sessions")
}

// Encrypted documents stored in R2/S3 — only the s3Key is stored here
model Document {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  uploadedById  String?
  uploadedBy    User?       @relation(fields: [uploadedById], references: [id])
  name          String      // display name, e.g. "Pay Stub - March 2025"
  s3Key         String      // e.g. "applications/{id}/paystub_march.pdf"
  mimeType      String
  sizeBytes     Int?
  createdAt     DateTime    @default(now())

  @@map("documents")
}

model Message {
  id        String   @id @default(cuid())
  leaseId   String
  lease     Lease    @relation(fields: [leaseId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@map("messages")
}

model LandlordSettings {
  id         String   @id @default(cuid())
  landlordId String   @unique
  landlord   User     @relation(fields: [landlordId], references: [id])
  settings   Json     @default("{}")
  updatedAt  DateTime @updatedAt

  @@map("landlord_settings")
}

model TenantInvite {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  email      String
  leaseId    String?
  landlordId String
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@map("tenant_invites")
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  unitId      String
  unit        Unit                @relation(fields: [unitId], references: [id])
  tenantId    String
  tenant      User                @relation(fields: [tenantId], references: [id])
  title       String
  description String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  imageUrls      String[]
  landlordNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("maintenance_requests")
}
